#!/bin/bash

# if [ "${0##*/}" != "bash" ] && [ "${SHELL##*/}" != "bash" ]; then
# echo "This script should be run with bash, not ${0##*/}"
# exit 1
# fi
function info() {
  echo "actual env:"
  echo "==========="
  env=$(readlink ~/.config/nvim)
  basename $env
  echo ""

  check_env
  exit 1
}

function list_env() {
  echo "env availables:"
  echo "==============="
  find ~/.config \( -type l -or -type d \) -iname 'nvim-*' -exec basename {} \; | sort
  echo ""
  echo "actual env:"
  echo "==========="
  env=$(readlink ~/.config/nvim)
  basename $env
  echo ""

  check_env
  exit 1
}

function is_symlink_folder() {
  if [[ -L "$1" && -d "$1" ]]; then
    echo "folder $1: ok"
    true
  else
    echo "folder $1 should be a symlink !"
    false
  fi
}

function check_env() {
  echo "Cheking actual env:"
  echo "==================="
  ISOK=true
  is_symlink_folder ~/.config/nvim || ISOK=false
  is_symlink_folder ~/.local/share/nvim || ISOK=false
  is_symlink_folder ~/.local/state/nvim || ISOK=false
  is_symlink_folder ~/.cache/nvim || ISOK=false
  echo ""
  $ISOK
}

function clear_nvim() {
  rm -f $HOME/.config/nvim
  rm -f $HOME/.local/share/nvim
  rm -f $HOME/.local/state/nvim
  rm -f $HOME/.cache/nvim
}

function usage() {
  local prog="${0##*/}"
  cat <<EOF
Usage: ${prog} [OPTIONS] [ENV]

Bascule Neovim vers un environnement de configuration (config, share, state, cache).

OPTIONS
  -h, --help       Afficher cette aide
  -d, --delete     Supprimer un environnement existant
  -i, --info       Afficher les informations sur l'environnement actuel
  -l, --list       Affiche la liste des environnement existant

COMMANDES
  ${prog}                    Menu interactif (gum) pour choisir un environnement
  ${prog} <env>              Basculer vers l'environnement (ex: nvim-lazyvim)
  ${prog} <nom>              Avec confirmation si le nom n'a pas le préfixe nvim-
  ${prog} --delete           Menu interactif pour choisir l'environnement à supprimer
  ${prog} --delete <env>     Supprimer l'environnement spécifié

EXEMPLES
  ${prog}                    # Choix interactif
  ${prog} nvim-lazyvim       # Bascule vers nvim-lazyvim
  ${prog} lazyvim            # Demande confirmation pour nvim-lazyvim
  ${prog} -d nvim-lazyvim    # Supprime nvim-lazyvim
EOF
}

function delete_env() {
  local ENV_NAME=$1
  local PATHS=(
    "$HOME/.config/${ENV_NAME}"
    "$HOME/.local/share/${ENV_NAME}"
    "$HOME/.local/state/${ENV_NAME}"
    "$HOME/.cache/${ENV_NAME}"
  )

  # Si c'est l'environnement actif, supprimer d'abord les symlinks
  local current_env
  current_env=$(readlink "$HOME/.config/nvim" 2>/dev/null | xargs basename 2>/dev/null || true)
  if [[ "$current_env" == "$ENV_NAME" ]]; then
    echo "Environnement actif : suppression des symlinks..."
    clear_nvim
  fi

  echo "Suppression de l'environnement ${ENV_NAME}..."
  for path in "${PATHS[@]}"; do
    if [[ -e "$path" ]]; then
      rm -rf "$path"
      echo "  supprimé: $path"
    fi
  done
  echo "Environnement ${ENV_NAME} supprimé."
}

# Aide
if [[ "$1" == "--help" || "$1" == "-h" ]]; then
  usage
  exit 0
fi

if [[ "$1" == "--info" || "$1" == "-i" ]]; then
  info
fi

if [[ "$1" == "--list" || "$1" == "-l" ]]; then
  list_env
fi

# Mode suppression : --delete ou -d
if [[ "$1" == "--delete" || "$1" == "-d" ]]; then
  shift
  if [[ $# -lt 1 ]]; then
    AVAILABLE_ENVS=$(find ~/.config \( -type l -or -type d \) -iname 'nvim-*' -exec basename {} \; | sort)
    if [[ -z "$AVAILABLE_ENVS" ]]; then
      echo "Aucun environnement nvim à supprimer."
      exit 1
    fi
    ENV_TO_DELETE=$(echo "$AVAILABLE_ENVS" | gum choose --header "Sélectionnez l'environnement à supprimer:")
    [[ -z "$ENV_TO_DELETE" ]] && exit 1
  else
    if [[ $1 != nvim-* ]]; then
      ENV_TO_DELETE="nvim-${1}"
    else
      ENV_TO_DELETE=$1
    fi
    if [[ ! -d "$HOME/.config/${ENV_TO_DELETE}" && ! -L "$HOME/.config/${ENV_TO_DELETE}" ]]; then
      echo "Environnement ${ENV_TO_DELETE} introuvable."
      exit 1
    fi
  fi

  echo -n "Confirmer la suppression de ${ENV_TO_DELETE} ? (y/N) "
  read -r choice
  case $choice in
  [Yy]) delete_env "$ENV_TO_DELETE" ;;
  *)
    echo "Annulé."
    exit 0
    ;;
  esac
  exit 0
fi

if [[ $# -lt 1 ]]; then
  # Choix interactif avec gum
  AVAILABLE_ENVS=$(find ~/.config \( -type l -or -type d \) -iname 'nvim-*' -exec basename {} \; | sort)
  if [[ -z "$AVAILABLE_ENVS" ]]; then
    echo "Aucun environnement nvim trouvé dans ~/.config"
    list_env
  fi
  ENV_NAME=$(echo "$AVAILABLE_ENVS" | gum choose --header "Sélectionnez un environnement Neovim:")
  [[ -z "$ENV_NAME" ]] && exit 1
elif [[ $1 != nvim-* ]]; then
  # Vérification de l'existence du dossier avant de poser la question
  CANDIDATE="nvim-${1}"
  if [[ ! -d "$HOME/.config/${CANDIDATE}" && ! -L "$HOME/.config/${CANDIDATE}" ]]; then
    echo "Environnement ${CANDIDATE} introuvable dans ~/.config"
    exit 1
  fi
  echo "Environment name should start with 'nvim-'"
  echo -n "Do you want to use ${CANDIDATE} ? "
  read choice
  case $choice in
  [Yy]) ENV_NAME="${CANDIDATE}" ;;
  *) exit 1 ;;
  esac
else
  ENV_NAME=$1
fi

if [ ! -d "$HOME/.config/${ENV_NAME}" ] && [ ! -L "$HOME/.config/${ENV_NAME}" ]; then
  echo -n "environment ${ENV_NAME} not found, do you want to create it ? "
  read choice
  case $choice in
  [Yy]) echo "ok, we will proceed" ;;
  [Nn]) exit 1 ;;
  esac
fi

if [[ ! check_env ]]; then
  echo "ERROR: env isn't clean"
  exit 1
fi

echo "Switch neovim to env ${ENV_NAME}"
clear_nvim

mkdir -p ~/.config/${ENV_NAME}
ln -s ~/.config/${ENV_NAME} ~/.config/nvim

mkdir -p ~/.local/share/${ENV_NAME}
ln -s ~/.local/share/${ENV_NAME} ~/.local/share/nvim

mkdir -p ~/.local/state/${ENV_NAME}
ln -s ~/.local/state/${ENV_NAME} ~/.local/state/nvim

mkdir -p ~/.cache/${ENV_NAME}
ln -s ~/.cache/${ENV_NAME} ~/.cache/nvim
